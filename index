<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TradeScope — International Market Intelligence</title>
  <meta name="description" content="International trade analytics and economic indicator summaries for major economies." />
  <link rel="stylesheet" href="css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="wrap">

    <!-- Header -->
    <header class="header">
      <div>
        <div class="site-title">TradeScope</div>
        <div class="site-subtitle">International Market &amp; Economic Intelligence</div>
      </div>
      <div class="header-right">
        <span class="updated" id="updated-label">Data as of March 2026</span>
        <a class="about-link" href="about.html">About</a>
      </div>
    </header>

    <!-- Selectors -->
    <div class="selector-row">
      <span class="selector-label">Region</span>
      <div class="select-wrap">
        <select id="region-select">
          <option value="all">All Regions</option>
          <option value="North America">North America</option>
          <option value="South America">South America</option>
          <option value="Western Europe">Western Europe</option>
          <option value="Southern Europe">Southern Europe</option>
          <option value="Northern Europe">Northern Europe</option>
          <option value="East Asia">East Asia</option>
          <option value="South Asia">South Asia</option>
          <option value="Southeast Asia">Southeast Asia</option>
          <option value="Middle East">Middle East</option>
          <option value="Southern Africa">Southern Africa</option>
          <option value="Oceania">Oceania</option>
          <option value="Latin America">Latin America</option>
        </select>
      </div>

      <span class="selector-label" style="margin-left:0.5rem">Country</span>
      <div class="select-wrap">
        <select id="country-select">
          <!-- Populated dynamically by app.js -->
        </select>
      </div>
    </div>

    <!-- Country Display -->
    <main id="country-display"></main>

    <!-- Footer -->
    <footer class="footer">
      TradeScope &middot; Sample data for portfolio purposes &middot; Sources: World Bank, IMF, OECD
    </footer>

  </div>

  <script src="js/data.js"></script>
  <script src="js/app.js"></script>
</body>
</html>
